# ============================================
# Backend Environment Variables Template
# ============================================
# คัดลอกไฟล์นี้เป็น .env และแก้ไขค่าตามต้องการ

# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# Database Configuration (MySQL with Prisma)
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=3308
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=eduweb_project
DATABASE_URL=mysql://root:@localhost:3308/eduweb_project

# ============================================
# Authentication
# ============================================
# JWT Secret Key - ใช้สำหรับ sign JWT tokens
# ⚠️  ต้องใช้ชื่อ JWT_SECRET_KEY เท่านั้น (ตามที่ verifyToken.js และ generateToken.js อ่านค่า)
# Production: ใช้ strong random string (อย่างน้อย 32 characters)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# JWT Expiration
JWT_EXPIRES_IN=7d

# ============================================
# CORS Configuration
# ============================================
# Frontend URL สำหรับ CORS
# Development
FRONTEND_URL=http://localhost:5173

# Production - เพิ่ม URLs อื่นๆ ถ้าจำเป็น
# FRONTEND_URL=https://your-frontend-domain.com

# ============================================
# File Upload Configuration
# ============================================
# ⚠️  หมายเหตุ: ค่า File Upload ถูก hardcode ในโค้ดโดยตรง ไม่ได้อ่านจาก env variable
# ดูและแก้ไขค่าได้ที่:
#   - backend/src/routes/upload.route.js     → fileSize: 5MB (รูปบทความ, รูปครู)
#   - backend/src/routes/homevisits.route.js → fileSize: 2MB, สูงสุด 5 ไฟล์ (รูปเยี่ยมบ้าน)
#   - backend/src/routes/profile.route.js    → fileSize: 2MB (รูปโปรไฟล์)
#
# ประเภทไฟล์ที่รองรับ (hardcoded): image/jpeg, image/jpg, image/png, image/gif, image/webp
# MAX_FILE_SIZE=5242880        ← ไม่ได้ถูกใช้จริง
# ALLOWED_FILE_TYPES=...       ← ไม่ได้ถูกใช้จริง

# ============================================
# Email Configuration (ถ้ามีระบบส่งอีเมล)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ============================================
# หมายเหตุ
# ============================================
# 1. ไฟล์ .env จะไม่ถูก commit ขึ้น Git (อยู่ใน .gitignore)
# 2. อย่าแชร์ค่า JWT_SECRET_KEY กับผู้อื่น
# 3. Production ต้องใช้ strong passwords และ secrets
# 4. ระบบใช้ MySQL (ไม่ใช่ MongoDB) ผ่าน Prisma ORM
