Table homeroom_classes {
  id int [pk, increment]
  className varchar(50) [unique, not null]
  homeroomTeacherId int [unique, not null, ref: > teachers.id]
  academicYearId int [ref: > academic_years.id]
  maxStudents int [default: 40]
  room varchar(50)
  floor int
  building varchar(50)
  isActive boolean [default: true]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
  deletedAt timestamp
  
  indexes {
    homeroomTeacherId
    academicYearId
    isActive [name: 'idx_homeroom_classes_active']
  }
}

Table academic_years {
  id int [pk, increment]
  year varchar(20) [unique, not null]
  startDate date [not null]
  endDate date [not null]
  isCurrent boolean [default: false]
  isActive boolean [default: true]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  createdBy int [ref: > users.id]
  updatedBy int [ref: > users.id]
  
  indexes {
    createdBy
    isActive [name: 'idx_academic_years_active']
    isCurrent [name: 'idx_academic_years_current']
    updatedBy
  }
}

Table academicclubs {
  id int [pk, increment]
  name varchar(100) [not null]
  description text
  maxMembers int
