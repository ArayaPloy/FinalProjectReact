// ─── GROUP: ข้อมูลอ้างอิง (Lookup) ──────────
TableGroup Lookups {
  userroles
  genders
  daysofweek
  attendancestatuses
}

// ─── GROUP: ผู้ใช้งาน (Users) ─────────────────
TableGroup Users {
  users
  password_reset_requests
  audit_logs
}

// ─── GROUP: โครงสร้างการศึกษา ─────────────────
TableGroup AcademicStructure {
  academic_years
  semesters
  departments
  subjects
  teachersubjects
}

// ─── GROUP: ครูและห้องเรียน ─────────────────
TableGroup TeachersAndClassrooms {
  teachers
  homeroom_classes
  classschedules
}

// ─── GROUP: นักเรียน ────────────────────────
TableGroup Students {
  students
  flagpoleattendance
  studentbehaviorscores
  homevisits
}

// ─── GROUP: ชมรมวิชาการ ─────────────────────
TableGroup Clubs {
  club_categories
  academicclubs
}

// ─── GROUP: บทความและข้อมูลโรงเรียน ──────────
TableGroup BlogsAndInfo {
  blog_categories
  blogs
  comments
  school_info
  school_timeline
  admissions_info
}

// =============================================
// LOOKUP / REFERENCE TABLES
// =============================================

Table userroles {
  id int [pk, increment]
  roleName varchar(50) [unique, not null, note: 'super_admin | admin | teacher | user']
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  deletedAt timestamp
}

Table genders {
  id int [pk, increment]
  genderName varchar(20) [unique, not null]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  deletedAt timestamp
}

Table daysofweek {
  id int [pk, increment]
  name varchar(20) [unique, not null, note: 'จันทร์ | อังคาร | พุธ | พฤหัสบดี | ศุกร์']
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  deletedAt timestamp
}

Table attendancestatuses {
  id int [pk, increment]
  name varchar(50) [unique, not null, note: 'มา | ขาด | ลา | สาย | ...']
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  isDeleted boolean [default: false]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    updatedBy
  }
}

// =============================================
// USERS & AUTH
// =============================================

Table users {
  id int [pk, increment]
  username varchar(255) [unique, not null]
  email varchar(255) [unique, not null]
  password varchar(255) [not null]
  roleId int [not null, ref: > userroles.id]
  phone varchar(20)
  profileImage varchar(255)
  lastLogin timestamp
  teacherId int [unique, ref: > teachers.id, note: 'โปรไฟล์ครูที่ผูกกับบัญชีนี้']
  mustChangePassword boolean [default: false]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  isDeleted boolean [default: false]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    roleId
    teacherId [name: 'users_teacherId_idx']
    updatedBy
  }
}

Table password_reset_requests {
  id int [pk, increment]
  userId int [not null, ref: > users.id]
  status varchar(20) [not null, default: 'pending', note: 'pending | approved | rejected']
  requestedAt timestamp [default: `now()`]
  resolvedAt timestamp
  resolvedBy int [ref: > users.id]

  indexes {
    userId
    status
    resolvedBy
  }
}

Table audit_logs {
  id int [pk, increment]
  userId int [ref: > users.id]
  tableName varchar(100) [not null]
  recordId int [not null]
  action varchar(20) [not null, note: 'INSERT | UPDATE | DELETE']
  oldValues text
  newValues text
  ipAddress varchar(45)
  userAgent text
  createdAt timestamp [default: `now()`]

  indexes {
    userId [name: 'idx_audit_user']
    action [name: 'idx_audit_action']
    createdAt [name: 'idx_audit_created']
    (tableName, recordId) [name: 'idx_audit_table_record']
  }
}

// =============================================
// ACADEMIC STRUCTURE
// =============================================

Table academic_years {
  id int [pk, increment]
  year varchar(20) [unique, not null, note: 'เช่น 2568']
  startDate date [not null]
  endDate date [not null]
  isCurrent boolean [default: false]
  isActive boolean [default: true]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  createdBy int [ref: > users.id]
  updatedBy int [ref: > users.id]

  indexes {
    createdBy
    updatedBy
    isActive [name: 'idx_academic_years_active']
    isCurrent [name: 'idx_academic_years_current']
  }
}

Table semesters {
  id int [pk, increment]
  academicYearId int [not null, ref: > academic_years.id]
  semesterNumber smallint [not null, note: '1 หรือ 2']
  startDate date [not null]
  endDate date [not null]
  isCurrent boolean [default: false]
  isActive boolean [default: true]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  createdBy int [ref: > users.id]
  updatedBy int [ref: > users.id]

  indexes {
    (academicYearId, semesterNumber) [unique, name: 'unique_semester_per_year']
    academicYearId
    createdBy
    updatedBy
    isActive [name: 'idx_semesters_active']
    isCurrent [name: 'idx_semesters_current']
  }
}

Table departments {
  id int [pk, increment]
  name varchar(100) [not null]
  headTeacherId int [unique, ref: > teachers.id]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  deletedAt timestamp
}

Table subjects {
  id int [pk, increment]
  codeSubject varchar(10) [unique, not null]
  name varchar(100) [not null]
  description text
  departmentId int [ref: > departments.id]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    departmentId
    updatedBy
  }
}

// =============================================
// TEACHERS
// =============================================

Table teachers {
  id int [pk, increment]
  namePrefix varchar(10)
  firstName varchar(100) [not null]
  lastName varchar(100) [not null]
  genderId int [not null, ref: > genders.id]
  departmentId int [ref: > departments.id]
  dob date
  nationality varchar(50)
  position varchar(50)
  level varchar(50)
  phoneNumber varchar(10)
  email varchar(100) [not null]
  address text [not null]
  education varchar(100) [not null]
  major varchar(100) [not null]
  biography text [not null]
  specializations text [not null]
  imagePath varchar(500) [not null]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  isDeleted boolean [default: false]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    departmentId
    genderId
    updatedBy
  }
}

Table teachersubjects {
  teacherId int [not null, ref: > teachers.id]
  subjectId int [not null, ref: > subjects.id]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  deletedAt timestamp

  indexes {
    (teacherId, subjectId) [pk]
    subjectId
  }
}

// =============================================
// CLASSROOMS & SCHEDULES
// =============================================

Table homeroom_classes {
  id int [pk, increment]
  className varchar(50) [unique, not null, note: 'เช่น ม.1/1']
  homeroomTeacherId int [unique, not null, ref: > teachers.id]
  academicYearId int [ref: > academic_years.id]
  maxStudents int [default: 40]
  room varchar(50)
  floor int
  building varchar(50)
  isActive boolean [default: true]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  deletedAt timestamp

  indexes {
    homeroomTeacherId
    academicYearId
    isActive [name: 'idx_homeroom_classes_active']
  }
}

Table classschedules {
  id int [pk, increment]
  class varchar(50) [not null, note: 'เช่น ม.1/1']
  subjectId int [ref: > subjects.id]
  teacherId int [ref: > teachers.id]
  dayOfWeekId int [ref: > daysofweek.id]
  semesterId int [ref: > semesters.id]
  periodNumber int [note: 'คาบที่']
  room varchar(50)
  building varchar(100)
  guestTeacherName varchar(255) [note: 'ครูพิเศษ (ถ้ามี)']
  subjectCodeRaw varchar(20) [note: 'รหัสวิชาแบบกรอกเอง']
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    subjectId
    teacherId
    dayOfWeekId
    semesterId
    updatedBy
    (class, semesterId) [name: 'idx_classschedules_class_semester']
  }
}

// =============================================
// STUDENTS
// =============================================

Table students {
  id int [pk, increment]
  namePrefix varchar(10)
  firstName varchar(100) [not null]
  lastName varchar(100) [not null]
  genderId int [not null, ref: > genders.id]
  homeroomClassId int [ref: > homeroom_classes.id]
  studentNumber int [note: 'รหัสนักเรียน']
  guardianNamePrefix varchar(10)
  guardianFirstName varchar(100)
  guardianLastName varchar(100)
  guardianRelation varchar(50)
  guardianOccupation varchar(100)
  guardianMonthlyIncome varchar(50)
  emergencyContact varchar(20)
  address text
  houseType varchar(100)
  houseMaterial varchar(200)
  utilities text
  studyArea varchar(100)
  dob date
  nationality varchar(50)
  weight int
  height int
  disease varchar(50)
  phoneNumber varchar(50)
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  isDeleted boolean [default: false]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    genderId
    homeroomClassId
    studentNumber [name: 'idx_student_number']
    updatedBy
  }
}

// =============================================
// ATTENDANCE & BEHAVIOR & HOME VISITS
// =============================================

Table flagpoleattendance {
  id int [pk, increment]
  studentId int [ref: > students.id]
  date date
  statusId int [not null, ref: > attendancestatuses.id]
  recorderId int [ref: > users.id, note: 'ครูที่บันทึก']
  semesterId int [ref: > semesters.id]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    studentId
    statusId
    recorderId
    semesterId
    updatedBy
    (date, semesterId) [name: 'idx_flagpole_date_semester']
  }
}

Table studentbehaviorscores {
  id int [pk, increment]
  studentId int [ref: > students.id]
  score int [not null, note: 'คะแนนที่หัก (ค่าลบ) หรือเพิ่ม (ค่าบวก)']
  comments text
  recorderId int [ref: > users.id, note: 'ครูที่บันทึก']
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  isDeleted boolean [default: false]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    studentId
    recorderId
    updatedBy
  }
}

Table homevisits {
  id int [pk, increment]
  teacherId int [not null, ref: > teachers.id]
  studentId int [not null, ref: > students.id]
  visitDate date [not null]
  parentNamePrefix varchar(20)
  parentFirstName varchar(100)
  parentLastName varchar(100)
  familyStatus text
  visitPurpose text [not null]
  studentBehaviorAtHome text
  parentCooperation text
  problems text
  recommendations text
  followUpPlan text
  summary text [not null]
  notes text
  imagePath varchar(500) [note: 'รูปหลัก']
  imageGallery text [note: 'JSON array ของ path รูปเพิ่มเติม']
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  isDeleted boolean [default: false]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    teacherId [name: 'idx_homevisits_teacher']
    studentId [name: 'idx_homevisits_student']
    updatedBy [name: 'idx_homevisits_updated_by']
    visitDate [name: 'idx_homevisits_visit_date']
    (teacherId, studentId) [name: 'idx_homevisits_teacher_student']
    (isDeleted, deletedAt) [name: 'idx_homevisits_deleted']
  }
}

// =============================================
// CLUBS
// =============================================

Table club_categories {
  id int [pk, increment]
  name varchar(100) [unique, not null]
  slug varchar(100) [unique, not null]
  description text
  icon varchar(50)
  sortOrder int [default: 0]
  relatedDepartmentId int [ref: > departments.id]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  isDeleted boolean [default: false]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    relatedDepartmentId
    updatedBy
    isDeleted [name: 'idx_club_categories_deleted']
  }
}

Table academicclubs {
  id int [pk, increment]
  name varchar(100) [not null]
  description text
  maxMembers int
  category varchar(100) [not null]
  categoryId int [ref: > club_categories.id]
  icon varchar(50) [not null]
  registrationDeadline date [not null]
  isActive boolean [default: true]
  meetingDay varchar(20)
  meetingTime varchar(20)
  location varchar(100)
  requirements text
  teacherId int [ref: > teachers.id, note: 'ครูที่ดูแลชมรม']
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    teacherId
    categoryId
    updatedBy
  }
}

// =============================================
// BLOGS & CONTENT
// =============================================

Table blog_categories {
  id int [pk, increment]
  name varchar(100) [unique, not null]
  slug varchar(100) [unique, not null]
  description text
  icon varchar(50)
  sortOrder int [default: 0]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  isDeleted boolean [default: false]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    updatedBy
    isDeleted [name: 'idx_blog_categories_deleted']
  }
}

Table blogs {
  id int [pk, increment]
  title varchar(255) [not null]
  description text
  coverImg varchar(255)
  content text
  category varchar(100)
  categoryId int [ref: > blog_categories.id]
  author int [ref: > users.id]
  status varchar(20) [not null, default: 'published', note: 'published | draft | pending | pending_update']
  pendingUpdateForId int [note: 'FK ชี้ไปยัง blogs.id ของบทความต้นฉบับ']
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  isDeleted boolean [default: false]
  deletedAt timestamp
  updatedBy int [ref: > users.id]

  indexes {
    author
    categoryId
    updatedBy
    status [name: 'idx_blogs_status']
  }
}

Table comments {
  id int [pk, increment]
  comment text [not null]
  userId int [not null, ref: > users.id]
  postId int [not null, ref: > blogs.id]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  deletedAt timestamp

  indexes {
    userId
    postId
  }
}

// =============================================
// SCHOOL INFORMATION (Standalone)
// =============================================

Table school_info {
  id int [pk, increment]
  name varchar(255) [not null, default: 'โรงเรียนท่าบ่อพิทยาคม']
  location text
  foundedDate varchar(50)
  currentDirector varchar(255)
  education_level varchar(255)
  department varchar(255)
  description text
  heroImage varchar(500)
  director_image varchar(500)
  director_quote text
  phone varchar(50)
  officeHoursOpen varchar(10)
  officeHoursClose varchar(10)
  email varchar(255)
  facebookUrl varchar(500)
  facebookName varchar(255)
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  createdBy int [not null]
  updatedBy int [not null]
  isDeleted boolean [default: false]
  deletedAt timestamp
  deletedBy int
}

Table school_timeline {
  id int [pk, increment]
  year int [not null]
  date varchar(50)
  title varchar(255) [not null]
  description text
  sortOrder int [default: 0]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  createdBy int [not null]
  updatedBy int [not null]
  isDeleted boolean [default: false]
  deletedAt timestamp
  deletedBy int
}

Table admissions_info {
  id int [pk, increment]
  bannerImage varchar(500)
  dateRange varchar(255)
  duration varchar(255)
  timeRange varchar(255)
  lunchBreak varchar(255)
  location varchar(500)
  mapUrl varchar(500)
  grade1Info varchar(500)
  grade4Info varchar(500)
  documents text
  conditions text
  contactName varchar(255)
  contactPhone varchar(50)
  facebookUrl varchar(500)
  facebookName varchar(255)
  createdAt timestamp [default: `now()`]
  updatedAt timestamp [default: `now()`]
  createdBy int [not null, default: 1]
  updatedBy int [not null, default: 1]
  isDeleted boolean [default: false]
}
