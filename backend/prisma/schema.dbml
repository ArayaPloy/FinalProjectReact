  parentNamePrefix varchar(20)
  parentFirstName varchar(100)
  parentLastName varchar(100)
  familyStatus text
  visitPurpose text [not null]
  studentBehaviorAtHome text
  parentCooperation text
  problems text
  recommendations text
  followUpPlan text
  summary text [not null]
  notes text
  imagePath varchar(500)
  imageGallery longtext
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
  isDeleted boolean [default: false]
  deletedAt timestamp
  
  indexes {
    (isDeleted, deletedAt) [name: 'idx_homevisits_deleted']
    studentId [name: 'idx_homevisits_student']
    teacherId [name: 'idx_homevisits_teacher']
    (teacherId, studentId) [name: 'idx_homevisits_teacher_student']
    updatedBy [name: 'idx_homevisits_updated_by']
    visitDate [name: 'idx_homevisits_visit_date']
  }
}

